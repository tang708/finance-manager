<!-- pages/budget/budget.wxml -->
<view class="container">
  <view class="nav-bar">
    <text class="nav-title">预算管理</text>
  </view>
  
  <view class="card" style="margin-top: 20rpx;">
    <view class="filter">
      <picker mode="date" fields="month" value="{{selectedMonth}}" bindchange="handleMonthChange">
        <view class="picker">
          <text>{{selectedMonth}}</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>
  
  <view class="card" style="margin-top: 20rpx;">
    <view class="budget-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx;">
      <text class="budget-title" style="font-size: 34rpx; font-weight: bold; color: var(--dark-color);">本月预算</text>
      <text class="budget-amount" style="font-size: 40rpx; font-weight: bold; color: var(--primary-color);">¥{{budget}}</text>
    </view>
    <view class="budget-progress" style="margin-bottom: 20rpx;">
      <view class="progress-bar" style="width: 100%; height: 20rpx; background-color: #f0f0f0; border-radius: 10rpx; overflow: hidden; margin-bottom: 10rpx;">
        <view class="progress-fill" style="width: {{progress}}%; height: 100%; background: linear-gradient(90deg, var(--primary-color), #667eea); border-radius: 10rpx; transition: width 0.3s ease;"></view>
      </view>
      <text class="progress-text" style="font-size: 28rpx; color: var(--info-color); text-align: right;">已使用 {{progress}}%</text>
    </view>
    <view class="budget-detail" style="display: flex; justify-content: space-between; padding-top: 20rpx; border-top: 1rpx solid var(--border-color);">
      <text class="detail-item" style="font-size: 30rpx; color: var(--dark-color);">已支出: ¥{{expense}}</text>
      <text class="detail-item" style="font-size: 30rpx; color: var(--success-color);">剩余: ¥{{remaining}}</text>
    </view>
  </view>
  
  <view class="card" style="margin-top: 20rpx; margin-bottom: 30rpx;">
    <view class="form-item">
      <label>设置预算</label>
      <input 
        class="input" 
        placeholder="请输入预算金额" 
        bindinput="handleBudgetInput"
        value="{{newBudget}}"
        type="number"
      />
    </view>
    
    <view class="error-message" wx:if="{{errorMessage}}">{{errorMessage}}</view>
    
    <view class="btn btn-primary" bindtap="handleSetBudget" wx:if="{{!loading}}">设置预算</view>
    <view class="loading" wx:else>
      <view class="loading-spinner"></view>
      <text style="margin-left: 20rpx;">设置中...</text>
    </view>
  </view>
</view>