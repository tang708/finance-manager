/* pages/ai-assistant/ai-assistant.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #303133;
}

.chat-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: scroll;
}

.message-item {
  margin-bottom: 20rpx;
  display: flex;
  align-items: flex-start;
}

.message-item.ai {
  justify-content: flex-start;
}

.message-item.user {
  justify-content: flex-end;
}

.message-avatar {
  font-size: 36rpx;
  margin: 0 10rpx;
  flex-shrink: 0;
}

.message-content {
  max-width: 80%;
  padding: 20rpx;
  border-radius: 12rpx;
  word-break: break-word;
}

.message-item.ai .message-content {
  background-color: white;
  border-bottom-left-radius: 0;
}

.message-item.user .message-content {
  background-color: #409EFF;
  color: white;
  border-bottom-right-radius: 0;
}

.message-text {
  font-size: 32rpx;
  line-height: 1.5;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.loading text {
  font-size: 28rpx;
  color: #909399;
}

.input-container {
  display: flex;
  padding: 20rpx;
  background-color: white;
  border-top: 1rpx solid #f0f0f0;
}

.input {
  flex: 1;
  border: 1rpx solid #dcdfe6;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.send-btn {
  background-color: #409EFF;
  color: white;
  border-radius: 8rpx;
  padding: 0 40rpx;
  font-size: 32rpx;
  border: none;
}

.send-btn:disabled {
  background-color: #c0c4cc;
}

.quick-questions {
  padding: 20rpx;
  background-color: white;
  border-top: 1rpx solid #f0f0f0;
}

.quick-title {
  font-size: 28rpx;
  color: #606266;
  margin-bottom: 10rpx;
  display: block;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.quick-item {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 15rpx 20rpx;
  font-size: 28rpx;
  color: #303133;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}
