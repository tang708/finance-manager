<!-- pages/ai-assistant/ai-assistant.wxml -->
<view class="container" style="display: flex; flex-direction: column; min-height: 100vh;">
  <view class="nav-bar">
    <text class="nav-title">智能财务助手</text>
  </view>
  
  <view class="chat-container" style="flex: 1; display: flex; flex-direction: column; background-color: var(--light-color);">
    <view class="message-list" id="messageList" style="flex: 1; padding: 20rpx; overflow-y: scroll;">
      <view class="message-item ai" wx:for="{{messages}}" wx:key="{{index}}" wx:if="{{!item.type || item.type === 'ai'}}">
        <view class="message-avatar">🤖</view>
        <view class="message-content" style="max-width: 80%; padding: 20rpx; border-radius: 12rpx; word-break: break-word; background-color: white; border-bottom-left-radius: 0; box-shadow: var(--shadow);">
          <text class="message-text" style="font-size: 32rpx; line-height: 1.5;">{{item.content}}</text>
        </view>
      </view>
      <view class="message-item user" wx:for="{{messages}}" wx:key="{{index}}" wx:if="{{item.type === 'user'}}">
        <view class="message-content" style="max-width: 80%; padding: 20rpx; border-radius: 12rpx; word-break: break-word; background-color: var(--primary-color); color: white; border-bottom-right-radius: 0; box-shadow: var(--shadow);">
          <text class="message-text" style="font-size: 32rpx; line-height: 1.5;">{{item.content}}</text>
        </view>
        <view class="message-avatar">👤</view>
      </view>
      <view class="loading" wx:if="{{loading}}" style="display: flex; justify-content: center; align-items: center; padding: 20rpx; margin-bottom: 20rpx;">
        <view class="loading-spinner" style="margin-right: 10rpx;"></view>
        <text style="font-size: 28rpx; color: var(--info-color);">助手正在思考...</text>
      </view>
    </view>
    
    <view class="card" style="margin: 20rpx; border-radius: var(--border-radius-lg); box-shadow: var(--shadow);">
      <view class="input-container" style="display: flex; padding: 20rpx; background-color: white; border-radius: var(--border-radius-lg);">
        <input 
          class="input" 
          placeholder="请输入您的财务问题..." 
          bindinput="handleInputChange"
          value="{{inputValue}}"
          bindconfirm="handleSend"
          style="flex: 1; border: 1rpx solid var(--border-color); border-radius: var(--border-radius); padding: 20rpx; font-size: 32rpx; margin-right: 20rpx; transition: var(--transition);"
        />
        <button class="btn btn-primary" bindtap="handleSend" disabled="{{loading || !inputValue}}" style="padding: 0 40rpx; font-size: 32rpx; border: none; margin-top: 0;">
          <text>发送</text>
        </button>
      </view>
    </view>
  </view>
  
  <view class="card" style="margin: 0 20rpx 20rpx 20rpx; border-radius: var(--border-radius-lg); box-shadow: var(--shadow);">
    <text class="quick-title" style="font-size: 28rpx; color: var(--info-color); margin-bottom: 10rpx; display: block; padding: 20rpx 20rpx 0 20rpx;">快速提问</text>
    <view class="quick-list" style="display: flex; flex-wrap: wrap; gap: 10rpx; padding: 20rpx;">
      <view class="quick-item" bindtap="handleQuickQuestion" data-question="如何制定合理的月度预算？" style="background-color: var(--light-color); border-radius: var(--border-radius); padding: 15rpx 20rpx; font-size: 28rpx; color: var(--dark-color); margin-right: 10rpx; margin-bottom: 10rpx; transition: var(--transition);">
        <text>如何制定合理的月度预算？</text>
      </view>
      <view class="quick-item" bindtap="handleQuickQuestion" data-question="如何节省日常开支？" style="background-color: var(--light-color); border-radius: var(--border-radius); padding: 15rpx 20rpx; font-size: 28rpx; color: var(--dark-color); margin-right: 10rpx; margin-bottom: 10rpx; transition: var(--transition);">
        <text>如何节省日常开支？</text>
      </view>
      <view class="quick-item" bindtap="handleQuickQuestion" data-question="如何分析我的消费习惯？" style="background-color: var(--light-color); border-radius: var(--border-radius); padding: 15rpx 20rpx; font-size: 28rpx; color: var(--dark-color); margin-right: 10rpx; margin-bottom: 10rpx; transition: var(--transition);">
        <text>如何分析我的消费习惯？</text>
      </view>
      <view class="quick-item" bindtap="handleQuickQuestion" data-question="如何提高我的储蓄率？" style="background-color: var(--light-color); border-radius: var(--border-radius); padding: 15rpx 20rpx; font-size: 28rpx; color: var(--dark-color); margin-right: 10rpx; margin-bottom: 10rpx; transition: var(--transition);">
        <text>如何提高我的储蓄率？</text>
      </view>
    </view>
  </view>
</view>