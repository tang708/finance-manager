/* app.wxss */

/* 全局变量 */
:root {
  --primary-color: #409EFF;
  --secondary-color: #67c23a;
  --danger-color: #f56c6c;
  --warning-color: #e6a23c;
  --info-color: #909399;
  --light-color: #f5f7fa;
  --dark-color: #303133;
  --border-color: #e4e7ed;
  --success-color: #67c23a;
  --shadow: 0 2rpx 12rpx 0 rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 4rpx 16rpx 0 rgba(0, 0, 0, 0.15);
  --border-radius: 12rpx;
  --border-radius-lg: 16rpx;
  --transition: all 0.3s ease;
}

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: var(--light-color);
  min-height: 100vh;
  color: var(--dark-color);
  font-size: 32rpx;
  line-height: 1.5;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 按钮样式 */
.btn {
  border-radius: var(--border-radius);
  text-align: center;
  padding: 20rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
  transition: var(--transition);
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), #667eea);
  color: white;
  box-shadow: var(--shadow);
}

.btn-primary:hover {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-lg);
}

.btn-secondary {
  background-color: var(--secondary-color);
  color: white;
  box-shadow: var(--shadow);
}

.btn-secondary:hover {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-lg);
}

.btn-danger {
  background-color: var(--danger-color);
  color: white;
  box-shadow: var(--shadow);
}

.btn-danger:hover {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-lg);
}

/* 输入框样式 */
.input {
  border: 1rpx solid var(--border-color);
  border-radius: var(--border-radius);
  padding: 20rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
  transition: var(--transition);
  background-color: white;
}

.input:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(64, 158, 255, 0.1);
}

/* 消息样式 */
.error-message {
  color: var(--danger-color);
  font-size: 28rpx;
  margin-top: 10rpx;
  padding: 10rpx 0;
}

.success-message {
  color: var(--success-color);
  font-size: 28rpx;
  margin-top: 10rpx;
  padding: 10rpx 0;
}

/* 加载样式 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(64, 158, 255, 0.2);
  border-left-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 导航栏样式 */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, var(--primary-color), #667eea);
  color: white;
  border-radius: 0 0 var(--border-radius-lg) var(--border-radius-lg);
  box-shadow: var(--shadow);
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow);
  padding: 30rpx;
  margin-bottom: 20rpx;
  transition: var(--transition);
}

.card:hover {
  transform: translateY(-5rpx);
  box-shadow: var(--shadow-lg);
}

/* 列表样式 */
.list {
  background-color: white;
  border-radius: var(--border-radius);
  overflow: hidden;
  margin-top: 20rpx;
  box-shadow: var(--shadow);
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 20rpx;
  border-bottom: 1rpx solid var(--border-color);
  transition: var(--transition);
}

.list-item:hover {
  background-color: #fafafa;
  padding-left: 30rpx;
}

.list-item:last-child {
  border-bottom: none;
}

/* 图表容器 */
.chart-container {
  width: 100%;
  height: 400rpx;
  margin-top: 20rpx;
  background-color: white;
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow);
  padding: 20rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  border-top: 1rpx solid var(--border-color);
  padding: 20rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 -2rpx 12rpx 0 rgba(0, 0, 0, 0.1);
}

.bottom-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: var(--border-radius);
  margin: 0 10rpx;
  transition: var(--transition);
}

/* 标题样式 */
.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--dark-color);
  margin: 30rpx 0 20rpx 0;
  position: relative;
  padding-left: 15rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 28rpx;
  background: linear-gradient(135deg, var(--primary-color), #667eea);
  border-radius: 4rpx;
}

/* 表单样式 */
.form {
  background-color: white;
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow);
  padding: 30rpx;
  margin-top: 20rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item label {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--dark-color);
  margin-bottom: 15rpx;
}

/* 选择器样式 */
.picker {
  border: 1rpx solid var(--border-color);
  border-radius: var(--border-radius);
  padding: 20rpx;
  font-size: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: white;
  transition: var(--transition);
}

.picker:hover {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(64, 158, 255, 0.1);
}

/* 快速操作按钮 */
.quick-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: white;
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow);
  transition: var(--transition);
  flex: 1;
  margin: 0 10rpx;
}

.quick-action:hover {
  transform: translateY(-5rpx);
  box-shadow: var(--shadow-lg);
}

.quick-action-icon {
  font-size: 64rpx;
  margin-bottom: 15rpx;
  color: var(--primary-color);
}

.quick-action-text {
  font-size: 28rpx;
  color: var(--dark-color);
  font-weight: 500;
}

/* 响应式设计 */
@media (max-width: 375px) {
  page {
    font-size: 28rpx;
  }
  
  .container {
    padding: 15rpx;
  }
  
  .btn {
    padding: 18rpx;
    font-size: 28rpx;
  }
  
  .input {
    padding: 18rpx;
    font-size: 28rpx;
  }
}
